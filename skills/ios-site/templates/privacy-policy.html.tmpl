<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{app_name}} — Privacy Policy</title>
    <style>
        body { font-family: -apple-system, system-ui, sans-serif; max-width: 680px; margin: 40px auto; padding: 0 20px; color: #1d1d1f; line-height: 1.6; }
        h1 { font-size: 28px; margin-bottom: 8px; }
        h2 { font-size: 20px; margin-top: 32px; }
        h3 { font-size: 16px; margin-top: 20px; }
        .date { color: #86868b; margin-bottom: 32px; }
        a { color: #0066cc; }
        table { width: 100%; border-collapse: collapse; margin: 16px 0; }
        th, td { border: 1px solid #d2d2d7; padding: 10px 12px; text-align: left; font-size: 14px; }
        th { background: #f5f5f7; font-weight: 600; }
        ul { padding-left: 24px; }
        li { margin-bottom: 6px; }
    </style>
</head>
<body>
    <h1>{{app_name}} Privacy Policy</h1>
    <p class="date">Last updated: {{last_updated}}</p>

    {{privacy_body_html}}

    <p style="margin-top: 48px; text-align: center;"><a href="index.html">Back to {{app_name}}</a></p>
</body>
</html>
