<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{app_name}} — Support</title>
    <style>
        body { font-family: -apple-system, system-ui, sans-serif; max-width: 680px; margin: 40px auto; padding: 0 20px; color: #1d1d1f; line-height: 1.6; }
        h1 { font-size: 28px; margin-bottom: 8px; }
        h2 { font-size: 20px; margin-top: 32px; }
        .subtitle { color: #86868b; margin-bottom: 32px; }
        .faq { background: #f5f5f7; border-radius: 12px; padding: 20px; margin-bottom: 16px; }
        .faq h3 { margin-top: 0; font-size: 17px; }
        .faq p { margin-bottom: 0; }
        a { color: #0066cc; }
    </style>
</head>
<body>
    <h1>{{app_name}} Support</h1>
    <p class="subtitle">Frequently asked questions and help</p>

    {{faq_html}}

    <div class="faq">
        <h3>Need more help?</h3>
        <p>Email <a href="mailto:{{support_email}}">{{support_email}}</a>.</p>
    </div>

    <p style="margin-top: 48px; text-align: center;"><a href="index.html">Back to {{app_name}}</a></p>
</body>
</html>
